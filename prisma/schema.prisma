// Mirrors the existing Sequelize schema produced by fitrock-api.
// Table names and snake_case columns are mapped explicitly with @map / @@map
// so this schema attaches to the existing database without renames.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id           Int      @id @default(autoincrement())
  full_name    String
  email        String   @unique
  password     String
  phone_number String?
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  carts        Cart[]

  @@map("Users")
}

model Filter {
  id            Int       @id @default(autoincrement())
  weight_amount Int
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  products      Product[]

  @@map("Filters")
}

model Product {
  id                  Int      @id @default(autoincrement())
  product_name        String
  product_price       Int
  product_description String?
  product_discount    Int?
  product_quantity    Int?
  product_weight      Int?
  filter_id           Int?
  filter              Filter?  @relation(fields: [filter_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  cartItems           Cart[]
  images              ProductImage[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("Products")
}

model ProductImage {
  id         Int      @id @default(autoincrement())
  product_id Int
  blob_key   String   @unique
  sort_order Int      @default(0)
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([product_id])
  @@map("ProductImages")
}

model Cart {
  id               Int      @id @default(autoincrement())
  product_id       Int
  product_quantity Int
  user_id          Int
  user             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  product          Product  @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("Carts")
}
